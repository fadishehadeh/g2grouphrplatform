# Redirect everything to public/ folder
<IfModule mod_rewrite.c>
    RewriteEngine On

    # If the request is NOT already inside public/
    RewriteCond %{REQUEST_URI} !^/.*public/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# Block direct access to sensitive files/folders
<FilesMatch "\.(env|sql|md|json|lock|phar|xml)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Block direct access to app directories
<IfModule mod_rewrite.c>
    RewriteRule ^(app|config|database|docs|routes|scripts|storage|tests|vendor)/ - [F,L]
</IfModule>

