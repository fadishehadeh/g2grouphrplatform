# ── Application ──────────────────────────────
APP_NAME="HR Management System"
APP_ENV=production
APP_DEBUG=false
# If app is in a subdirectory use: https://yourdomain.com/hr2
APP_URL=https://yourdomain.com
APP_TIMEZONE=Asia/Qatar

# ── Database ─────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_cpanel_db_name
DB_USERNAME=your_cpanel_db_user
DB_PASSWORD=your_cpanel_db_password

# ── Mail ─────────────────────────────────────
MAIL_ENABLED=true
MAIL_TRANSPORT=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=hr@yourdomain.com
MAIL_FROM_NAME="HR Management System"

# ── Careers Database ─────────────────────────
# Leave blank to fall back to the main DB_* credentials above.
# On cPanel the database name will be prefixed, e.g. greykktq_hrsystemcareers
CAREERS_DB_HOST=
CAREERS_DB_PORT=
CAREERS_DB_DATABASE=your_cpanel_careers_db_name
CAREERS_DB_USERNAME=
CAREERS_DB_PASSWORD=

# ── Session ──────────────────────────────────
SESSION_NAME=hr_system_session
SESSION_IDLE_TIMEOUT=7200
# ── GitHub Deployment ─────────────────────
# Auto-deployment webhook secret from GitHub
# Generate a strong random string in GitHub Webhook settings
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret_here
